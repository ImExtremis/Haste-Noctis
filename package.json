{
	"name": "noctis",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "sh scripts/run_dev.sh",
		"dev:docs": "cd noctis_docs && npx mint dev --no-open",
		"dev:cassandra": "NOCTIS_DATABASE=cassandra sh scripts/run_dev.sh",
		"docs:generate": "node noctis_docs/scripts/generate_resources.mjs && node noctis_docs/scripts/generate_config.mjs && node noctis_docs/scripts/generate_media_proxy.mjs",
		"docs:generate:config": "node noctis_docs/scripts/generate_config.mjs",
		"docs:generate:media-proxy": "node noctis_docs/scripts/generate_media_proxy.mjs",
		"docs:generate:resources": "node noctis_docs/scripts/generate_resources.mjs",
		"i18n:generate": "pnpm --filter @noctis/i18n generate:types",
		"i18n:prune:apply": "pnpm --filter @noctis/i18n prune:apply",
		"i18n:prune:dry": "pnpm --filter @noctis/i18n prune:dry",
		"i18n:typecheck": "pnpm --filter @noctis/errors --filter @noctis/email --filter @noctis/marketing typecheck",
		"knip": "pnpm --filter noctis_app i18n:compile && NOCTIS_CONFIG=config/config.test.json knip",
		"lint": "turbo run lint",
		"schema:generate": "pnpm --filter @noctis/config run generate && node noctis_docs/scripts/generate_config.mjs",
		"test": "turbo run test --filter='!@noctis/integration'",
		"test:integration": "pnpm --filter @noctis/integration test",
		"typecheck": "turbo run typecheck"
	},
	"prettier": {
		"bracketSpacing": false,
		"printWidth": 120,
		"singleQuote": true,
		"tabWidth": 2,
		"useTabs": true
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"knip": "catalog:",
		"turbo": "^2.8.3"
	},
	"packageManager": "pnpm@10.29.3",
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"react": "*"
			},
			"ignoreMissing": [
				"webpack",
				"babel-plugin-macros"
			]
		},
		"overrides": {
			"@lingui/swc-plugin": "catalog:",
			"@rspack/cli": "catalog:",
			"@rspack/core": "catalog:"
		},
		"patchedDependencies": {
			"@phosphor-icons/react@2.1.10": "patches/@phosphor-icons__react@2.1.10.patch"
		},
		"trustPolicies": [
			{"name": "@babel/core>semver", "trustType": "downgrade"},
			{"name": "semver", "trustType": "downgrade"}
		]
	}
}
