{
	"name": "noctis_server",
	"version": "0.0.0",
	"private": true,
	"description": "Combined umbrella service for self-hosters bringing together all TypeScript backend services",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --clear-screen=false src/startServer.tsx",
		"start": "tsx src/startServer.tsx",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@noctis/admin": "workspace:*",
		"@noctis/api": "workspace:*",
		"@noctis/app_proxy": "workspace:*",
		"@noctis/config": "workspace:*",
		"@noctis/constants": "workspace:*",
		"@noctis/errors": "workspace:*",
		"@noctis/hono": "workspace:*",
		"@noctis/hono_types": "workspace:*",
		"@noctis/initialization": "workspace:*",
		"@noctis/ip_utils": "workspace:*",
		"@noctis/kv_client": "workspace:*",
		"@noctis/logger": "workspace:*",
		"@noctis/media_proxy": "workspace:*",
		"@noctis/nats": "workspace:*",
		"@noctis/s3": "workspace:*",
		"@noctis/sentry": "workspace:*",
		"hono": "catalog:",
		"tsx": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"packageManager": "pnpm@10.29.3",
	"engines": {
		"node": ">=24.0.0"
	}
}
